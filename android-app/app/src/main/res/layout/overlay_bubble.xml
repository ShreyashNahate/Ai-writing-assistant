<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="end">

    <!-- Draggable bubble -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/iv_bubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_menu_edit"
        app:backgroundTint="#6C63FF"
        app:tint="@android:color/white"
        android:layout_gravity="end"/>

    <!-- Action panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/action_panel"
        android:layout_width="230dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_gravity="end"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="AI Assistant"
                    android:textSize="13sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                <TextView android:id="@+id/btn_close_panel" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="✕"
                    android:textSize="14sp" android:textColor="#6B6B8A" android:padding="4dp"/>
            </LinearLayout>

            <!-- Row 1 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btn_improve"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="Improve" android:textSize="11sp" android:layout_marginEnd="4dp"
                    app:cornerRadius="8dp" app:strokeColor="#6C63FF"/>
                <Button android:id="@+id/btn_shorten"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="Shorten" android:textSize="11sp"
                    app:cornerRadius="8dp" app:strokeColor="#6C63FF"/>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <Button android:id="@+id/btn_formal"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="Formal" android:textSize="11sp" android:layout_marginEnd="4dp"
                    app:cornerRadius="8dp" app:strokeColor="#6C63FF"/>
                <Button android:id="@+id/btn_grammar"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="Grammar" android:textSize="11sp"
                    app:cornerRadius="8dp" app:strokeColor="#6C63FF"/>
            </LinearLayout>

            <!-- Row 3 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <Button android:id="@+id/btn_reply"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="Reply" android:textSize="11sp" android:layout_marginEnd="4dp"
                    app:cornerRadius="8dp" app:strokeColor="#6C63FF"/>
                <Button android:id="@+id/btn_expand"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="Expand" android:textSize="11sp"
                    app:cornerRadius="8dp" app:strokeColor="#6C63FF"/>
            </LinearLayout>

            <!-- Result (tap to copy) -->
            <TextView android:id="@+id/tv_result"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:minHeight="48dp" android:textSize="13sp" android:textColor="#1A1A2E"
                android:lineSpacingMultiplier="1.3" android:background="#F3F2FF"
                android:padding="10dp" android:clickable="true" android:focusable="true"
                android:visibility="gone"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
