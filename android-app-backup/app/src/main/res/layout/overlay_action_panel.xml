<?xml version="1.0" encoding="utf-8"?>
<!-- NO MaterialCardView, NO Material Button — Service has no Material theme context -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingBottom="12dp">

    <!-- Card replacement: plain LinearLayout with background + elevation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_overlay_panel"
        android:elevation="12dp"
        android:padding="14dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✨ AI Assistant"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

            <TextView
                android:id="@+id/btn_close_panel"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="✕"
                android:textSize="16sp"
                android:textColor="#6B6B8A"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_close_btn" />

        </LinearLayout>

        <!-- Row 1: Improve + Shorten -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btn_improve"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Improve ✨"
                android:textSize="12sp"
                android:textColor="#6C63FF"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_overlay_btn" />

            <TextView
                android:id="@+id/btn_shorten"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Shorten ✂️"
                android:textSize="12sp"
                android:textColor="#6C63FF"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_overlay_btn" />

        </LinearLayout>

        <!-- Row 2: Formal + Grammar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/btn_formal"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Formal 🎩"
                android:textSize="12sp"
                android:textColor="#6C63FF"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_overlay_btn" />

            <TextView
                android:id="@+id/btn_grammar"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Grammar ✅"
                android:textSize="12sp"
                android:textColor="#6C63FF"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_overlay_btn" />

        </LinearLayout>

        <!-- Row 3: Reply + Expand -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/btn_reply"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Reply 💬"
                android:textSize="12sp"
                android:textColor="#6C63FF"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_overlay_btn" />

            <TextView
                android:id="@+id/btn_expand"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Expand 📝"
                android:textSize="12sp"
                android:textColor="#6C63FF"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_overlay_btn" />

        </LinearLayout>

        <!-- Result — tap to paste -->
        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="52dp"
            android:textSize="13sp"
            android:textColor="#1A1A2E"
            android:lineSpacingMultiplier="1.4"
            android:background="@drawable/bg_result_area"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>